# LiveKit server WebSocket URL the agent worker connects to.
# Local dev (sibling livekit-server): ws://localhost:7880
# Production: wss://<your-project>.livekit.cloud
LIVEKIT_URL=

# LiveKit project API key. Required.
LIVEKIT_API_KEY=

# LiveKit project API secret. Required. Never commit a real value.
LIVEKIT_API_SECRET=

# Dispatch name the worker registers with. Backend-service must pass this
# value to AgentDispatchClient.createDispatch() to invoke this worker.
# Setting AGENT_NAME enables explicit dispatch (automatic dispatch disabled).
AGENT_NAME=

# Pino log level: trace | debug | info | warn | error | fatal. Defaults to "info" when unset.
LOG_LEVEL=
