{
  "name": "agent-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone @livekit/agents worker for the agent-assistant project. Registers an entrypoint under an explicit agentName so backend-service controls dispatch.",
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch src/main.ts dev",
    "start": "node dist/main.js start",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@livekit/agents": "^1.4.2",
    "@livekit/rtc-node": "^0.13.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^30.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
