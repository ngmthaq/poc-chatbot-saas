{
  "name": "agent-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone @livekit/agents worker for the agent-assistant project. Registers an entrypoint under an explicit agentName so backend-service controls dispatch.",
  "type": "commonjs",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch src/main.ts dev",
    "start": "node dist/main.js start",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@livekit/agents": "^1.4.2",
    "@livekit/rtc-node": "^0.13.0",
    "pino": "^9.5.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
