# backend-service environment template.
#
# DO NOT fill these values by hand and DO NOT commit a real `.env` file.
# Generate the real `.env` (mode 600) by running:
#
#   bash scripts/bootstrap.sh
#
# Rotate secrets later with `bash scripts/bootstrap.sh --force` — it will
# write a timestamped backup (`.env.bak.<ts>`) before overwriting.

# Application
NODE_ENV=
PORT=
API_PREFIX=
LOG_LEVEL=
SWAGGER_PATH=
CORS_ORIGINS=

# Database
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=
# assembled by bootstrap.sh from DB_* — do not hand-edit.
DATABASE_URL=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# Encryption — must be exactly 64 hex chars / 32 bytes for AES-256-GCM.
ENCRYPTION_KEY=

# Hashing
BCRYPT_SALT_ROUNDS=

# Throttling
THROTTLE_TTL=
THROTTLE_LIMIT=

# File uploads
FILE_STORAGE_DRIVER=
UPLOAD_LOCAL_DIR=

# AWS S3 (only required when FILE_STORAGE_DRIVER=s3)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_PATH=livekit/webhook
LIVEKIT_SIP_TRUNK_ID=
LIVEKIT_DEFAULT_TOKEN_TTL_SECONDS=3600
# agentName used for explicit dispatch via AgentDispatchClient. Must match the
# name the agent-worker process registers with @livekit/agents-js. Defaults to
# 'voice-agent' when unset.
LIVEKIT_AGENT_NAME=
