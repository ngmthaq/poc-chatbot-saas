# LiveKit server environment template.
#
# DO NOT fill these values in by hand and DO NOT commit a real `.env` file.
# Generate the real `.env` (mode 600) by running:
#
#   bash scripts/bootstrap.sh
#
# Rotate secrets later with `bash scripts/bootstrap.sh --force` — it will
# write a timestamped backup before overwriting.

# LiveKit API key (identifier). Generated by bootstrap; ~16 chars.
LIVEKIT_API_KEY=

# LiveKit API secret. Generated by bootstrap; >= 32 chars of entropy.
LIVEKIT_API_SECRET=

# Redis AUTH password. Generated by bootstrap; >= 32 chars of entropy.
REDIS_PASSWORD=

# Public DNS name advertised by the built-in TURN/TLS listener. Replace
# `example.com` with the real domain once you enable the TURN block in
# `livekit.yaml` and place real `tls.crt`/`tls.key` into `./certs/`.
LIVEKIT_TURN_DOMAIN=example.com
