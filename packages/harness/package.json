{
  "name": "@call-center-agent/harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./livekit": {
      "types": "./dist/adapters/livekit.adapter.d.ts",
      "import": "./dist/adapters/livekit.adapter.js"
    },
