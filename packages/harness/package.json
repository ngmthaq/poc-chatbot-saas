    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@livekit/agents": "^1.4.3",
    "langchain": "^1.4.4",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
