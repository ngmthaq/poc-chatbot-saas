{
  "name": "infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose --env-file .env.local --profile dev up -d --build",
    "dev:down": "docker compose --env-file .env.local --profile dev down",
    "prod": "docker compose --env-file .env.local --profile prod up -d --build",
    "prod:down": "docker compose --env-file .env.local --profile prod down",
    "build": "docker compose --env-file .env.local build"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {},
  "devDependencies": {}
}
