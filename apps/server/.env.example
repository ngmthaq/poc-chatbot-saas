# ================================================================
# Express.js server environment variables
# ================================================================
PORT=3000
NODE_ENV=development

# ================================================================
# LiveKit server connection settings
# Get these values from your LiveKit server configuration
# (infra/.env)
# ================================================================
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_AGENT_NAME=call-center-agent

# ================================================================
# PostgreSQL database connection (Prisma)
# DATABASE_URL is the Prisma connection string. The value below is the
# local-dev default provisioned by the infra docker-compose stack — not a
# secret (matches the committed devkey/devsecret placeholder convention).
# ================================================================
DATABASE_URL=postgresql://callcenter_user:callcenter_password@localhost:5432/callcenter_dev?schema=public

# ================================================================
# Platform-admin auth (POST /admin/auth/login)
# ADMIN_JWT_SECRET signs admin JWT access tokens — REQUIRED (no default).
# ADMIN_ACCESS_TOKEN_TTL is the access-token lifetime (e.g. 15m).
# ADMIN_REFRESH_TOKEN_TTL_DAYS is the refresh-token lifetime in days.
# KEYS ONLY — do not commit a real secret value.
# ================================================================
ADMIN_JWT_SECRET=
ADMIN_ACCESS_TOKEN_TTL=15m
ADMIN_REFRESH_TOKEN_TTL_DAYS=7

# ================================================================
# Text-chat (deepagent) settings
# LLM_PROVIDER selects the deepagent LLM provider (OPENAI | MISTRAL | ANTHROPIC)
# ================================================================
LLM_PROVIDER=OPENAI

# ================================================================
# Provider API keys — read by LangChain/harness from process.env.
# Set the key matching your LLM_PROVIDER. TWELVE_DATA_API_KEY backs
# agent data tools; TAVILY_API_KEY enables the web-search tool.
# KEYS ONLY — do not commit values.
# ================================================================
OPENAI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
TWELVE_DATA_API_KEY=
TAVILY_API_KEY=

# ================================================================
# Voice mode kill switch
# VOICE_MODE_ENABLED toggles voice mode at runtime (true | false).
# Default true; unset means voice enabled. When false, the client hides
# the Voice toggle and POST /livekit/token returns 403.
# ================================================================
VOICE_MODE_ENABLED=true
