// Conversation domain: end-users and persisted conversations/messages.
//
// EndUser is the (optional) identity of whoever chats with a tenant's bot,
// de-duplicated per tenant via the client-supplied `externalId`. A Conversation
// maps to the existing client-supplied `threadId` concept (unique per tenant)
// and may flow over a TEXT or VOICE channel. Deleting a Conversation cascades
// its Messages. Wiring chat.service.ts/deepagent to write these rows is an
// explicit follow-up — this is schema only.

enum Channel {
  TEXT
  VOICE
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model EndUser {
  id          String   @id @default(uuid())
  tenantId    String
  externalId  String?
  displayName String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
}

model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  botId         String
  endUserId     String?
  apiKeyId      String?
  threadId      String
  channel       Channel            @default(TEXT)
  title         String?
  status        ConversationStatus @default(ACTIVE)
  startedAt     DateTime           @default(now())
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  endUser  EndUser?  @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  apiKey   ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([tenantId, threadId])
  @@index([tenantId])
  @@index([botId])
  @@index([endUserId])
  @@index([apiKeyId])
  @@index([lastMessageAt])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  tokenCount     Int?
  toolName       String?
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
