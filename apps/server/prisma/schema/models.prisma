// Per-domain model files convention.
//
// Add domain models here, or split them into their own files named after the
// domain (e.g. `user.prisma`, `call.prisma`, `agent.prisma`). Every *.prisma
// file in this folder is loaded automatically alongside schema.prisma, so the
// datasource/generator defined there apply to models declared in any sibling
// file.
//
// Example:
//
// model User {
//   id        String   @id @default(uuid())
//   email     String   @unique
//   createdAt DateTime @default(now())
// }
