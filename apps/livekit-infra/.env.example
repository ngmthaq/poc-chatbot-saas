# LiveKit Server Credentials
# These values are used by the LiveKit CLI and other tooling (e.g. lk CLI).
# IMPORTANT: You MUST also update the keys section in livekit.yaml with your actual
# API key:secret pair — the Go YAML parser does NOT expand ${VAR} placeholders.
# See livekit.yaml keys section for instructions.
LIVEKIT_API_KEY=

# The API secret paired with the API key — keep this value private
LIVEKIT_API_SECRET=

# Domain Configuration
# Primary LiveKit WebSocket/HTTP domain (e.g. livekit.YOURDOMAIN.COM)
LIVEKIT_DOMAIN=

# TURN server domain for ICE/STUN/TURN (e.g. livekit-turn.YOURDOMAIN.COM)
LIVEKIT_TURN_DOMAIN=

# PostgreSQL — Application Database
# Name of the PostgreSQL database used by the call-center-agent application
POSTGRES_DB=

# PostgreSQL superuser / application user
POSTGRES_USER=

# Password for the PostgreSQL user — keep this value private
POSTGRES_PASSWORD=

# Certbot / Let's Encrypt
# Email address used for certificate expiry notifications and recovery
CERTBOT_EMAIL=

# Redis App
# Host port exposed for the redis-app container (default: 6380 to avoid conflict with redis-livekit on 6379)
REDIS_APP_PORT=6380
