# ================================================================
# LiveKit agent environment variables
# These variables configure the LiveKit agent's connection
# to the LiveKit server. Get your environment values from
# your LiveKit server configuration (livekit-infra/.env).
# ================================================================
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=call-center-agent

# ================================================================
# Third-party API keys
# These variables store API keys for various third-party services
# used by the LiveKit agent. Fill in your API keys here.
# ================================================================
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=
CARTESIA_API_KEY=
NEUPHONIC_API_KEY=
RESEMBLE_API_KEY=
RIME_API_KEY=
INWORLD_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
FISH_API_KEY=
HUME_API_KEY=