# ================================================================
# LiveKit agent environment variables
# These variables configure the LiveKit agent's connection
# to the LiveKit server. Get your environment values from
# your LiveKit server configuration (infra/.env).
# ================================================================
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_AGENT_NAME=call-center-agent

# ================================================================
# Provider selection
# Selects which provider powers the LLM, STT, and TTS pipelines.
# Valid values are the ProviderType member names:
#   INFERENCE, OPENAI, GOOGLE, DEEPGRAM, ELEVEN, CARTESIA,
#   NEUPHONIC, RESEMBLE, RIME, INWORLD, MISTRAL, XAI, FISH, HUME
# (each provider only supports the pipelines registered for it).
# All default to MISTRAL when unset.
# ================================================================
LLM_PROVIDER=MISTRAL
STT_PROVIDER=MISTRAL
TTS_PROVIDER=MISTRAL

# ================================================================
# Third-party API keys
# These variables store API keys for various third-party services
# used by the LiveKit agent. Fill in your API keys here.
# ================================================================
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=
CARTESIA_API_KEY=
NEUPHONIC_API_KEY=
RESEMBLE_API_KEY=
RIME_API_KEY=
INWORLD_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
FISH_API_KEY=
HUME_API_KEY=
TWELVE_DATA_API_KEY=
TAVILY_API_KEY=
