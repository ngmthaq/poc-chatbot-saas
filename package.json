{
  "name": "call-center-agent",
  "version": "1.0.27",
  "private": true,
  "description": "Call center AI agent monorepo",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "copy-env": "bash scripts/copy-env.sh",
    "livekit-agent": "pnpm --filter livekit-agent $*",
    "livekit-server": "pnpm --filter livekit-server $*",
    "livekit-client": "pnpm --filter livekit-client $*",
    "livekit-infra": "pnpm --filter livekit-infra $*"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "call-center",
    "ai-agent",
    "livekit",
    "voice-ai",
    "monorepo"
  ],
  "author": "Victor Nguyen <ngmthaq.20@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.3"
  }
}
